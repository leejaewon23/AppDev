
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 공통 헬퍼 함수 ───────────────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }
    function isMemberOf(resource) {
      return isLoggedIn() && request.auth.uid in resource.data.memberUids;
    }
    function isAuthorOfPost() {
      return isLoggedIn() && resource.data.authorUid == request.auth.uid;
    }
    function isValidPostCreate() {
      return request.resource.data.authorUid == request.auth.uid
             && request.resource.data.memberUids.size() == 1
             && request.auth.uid in request.resource.data.memberUids
             && request.resource.data.currentMembers == 1
             && request.resource.data.maxMembers >= 2
             && request.resource.data.currentMembers <= request.resource.data.maxMembers
             && request.resource.data.recruiting == true;
    }
    function isValidSelfJoin() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let nextCount = resource.data.currentMembers + 1;
      let nextRecruiting = nextCount < resource.data.maxMembers;
      return resource.data.recruiting == true
             && resource.data.currentMembers < resource.data.maxMembers
             && !(request.auth.uid in resource.data.memberUids)
             && request.auth.uid in request.resource.data.memberUids
             && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
             && request.resource.data.currentMembers == nextCount
             && request.resource.data.currentMembers <= resource.data.maxMembers
             && request.resource.data.recruiting == nextRecruiting
             && changedKeys.hasOnly(['memberUids', 'currentMembers', 'recruiting', 'updatedAt']);
    }
    function isValidChatRoomLink(postId) {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let currentChatRoomId = resource.data.chatRoomId == null ? '' : resource.data.chatRoomId;
      return request.auth.uid in resource.data.memberUids
             && currentChatRoomId == ''
             && request.resource.data.chatRoomId == postId
             && changedKeys.hasOnly(['chatRoomId', 'updatedAt']);
    }
    function isValidRoomCreate(roomId) {
      return isLoggedIn()
             && request.resource.data.type == 'GROUP'
             && request.resource.data.studyPostId == roomId
             && request.resource.data.roomName is string
             && request.resource.data.lastMessage is string
             && request.resource.data.lastMessageAt is timestamp
             && request.auth.uid in request.resource.data.memberUids
             && request.resource.data.memberUids ==
                get(/databases/$(database)/documents/studyPosts/$(request.resource.data.studyPostId)).data.memberUids;
    }
    function isValidRoomMetadataUpdate() {
      return isMemberOf(resource)
             && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['lastMessage', 'lastMessageAt']);
    }
    function isValidRoomSelfJoin() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let postAfter = getAfter(
        /databases/$(database)/documents/studyPosts/$(resource.data.studyPostId)
      ).data;
      return request.auth.uid in postAfter.memberUids
             && !(request.auth.uid in resource.data.memberUids)
             && request.auth.uid in request.resource.data.memberUids
             && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
             && changedKeys.hasOnly(['memberUids']);
    }

    // ── 유저 프로필 ─────────────────────────────────────────────
    match /users/{uid} {
      // 누구나 프로필 읽기 가능 (닉네임 표시 등)
      allow read: if isLoggedIn();
      // 본인 프로필만 수정 가능
      allow write: if isOwner(uid);
    }

    // ── 스터디 게시글 ────────────────────────────────────────────
    match /studyPosts/{postId} {
      // 로그인한 유저 모두 읽기 가능
      allow read: if isLoggedIn();
      // 로그인한 유저는 게시글 생성 가능
      allow create: if isLoggedIn() && isValidPostCreate();
      // 수정: 작성자만 가능. 예외적으로 참여자는 본인 참여 처리와 채팅방 연결만 가능.
      allow update: if isLoggedIn() && (
          isAuthorOfPost()
          || isValidSelfJoin()
          || isValidChatRoomLink(postId)
      );
      // 삭제: 작성자만 가능
      allow delete: if isOwner(resource.data.authorUid);
    }

    // ── 채팅방 ───────────────────────────────────────────────────
    match /chatRooms/{roomId} {
      // 채팅방 멤버만 읽기 가능
      allow read: if isMemberOf(resource);
      // 그룹 채팅방은 스터디당 1개로 고정
      allow create: if isValidRoomCreate(roomId);
      // 메시지 메타데이터 갱신 또는 방 참여 동기화만 허용
      allow update: if isValidRoomMetadataUpdate() || isValidRoomSelfJoin();

      // ── 메시지 서브컬렉션 ────────────────────────────────────
      match /messages/{messageId} {
        // 채팅방 멤버만 메시지 읽기/쓰기 가능
        allow read: if isLoggedIn()
                    && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.memberUids;
        allow create: if isLoggedIn()
                      && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.memberUids
                      && request.resource.data.senderUid == request.auth.uid;
        // 메시지 수정/삭제 불가 (채팅 무결성)
        allow update, delete: if false;
      }
    }
  }
}
